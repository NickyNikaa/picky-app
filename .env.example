# --- Anthropic (für AI-Fallback bei unstrukturierten Websites) ---
# Free trial credits unter https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- Eventbrite (optional — nur wenn eigene Org) ---
EVENTBRITE_TOKEN=

# --- GitHub Gist (KOSTENLOSER Storage für Cowork-curated Events) ---
# 1. https://github.com/settings/tokens → "gist"-Scope
# 2. Gist anlegen mit Datei "picky-events.json", Inhalt "[]"
GITHUB_TOKEN=ghp_...
GIST_ID=...

# --- Schutz für /api/submit-events Endpoint (Cowork → Backend) ---
PICKY_SUBMIT_TOKEN=langes-zufaelliges-secret-token

# --- Cron-Endpoint-Schutz (Vercel Cron) ---
CRON_SECRET=ein-langes-zufaelliges-token
